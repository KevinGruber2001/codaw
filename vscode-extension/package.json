{
  "name": "codaw",
  "displayName": "codaw",
  "description": "A extension to better manage your CodaW sessions",
  "version": "0.1.2",
  "publisher": "kevingruber",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/KevinGruber2001/codaw.git",
    "directory": "vscode-extension"
  },
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "codaw.trackEditor",
        "displayName": "CodaW Track",
        "selector": [
          {
            "filenamePattern": "**/tracks/*.toml"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "codaw.busEditor",
        "displayName": "CodaW Bus",
        "selector": [
          {
            "filenamePattern": "**/buses/*.toml"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "codaw.masterEditor",
        "displayName": "CodaW Master",
        "selector": [
          {
            "filenamePattern": "**/master.toml"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "codaw.projectEditor",
        "displayName": "CodaW Project",
        "selector": [
          {
            "filenamePattern": "**/project.toml"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "codaw.togglePlay",
        "title": "CodaW: Play / Pause"
      },
      {
        "command": "codaw.stop",
        "title": "CodaW: Stop (return to start)"
      },
      {
        "command": "codaw.openMixer",
        "title": "CodaW: Open Mixer"
      }
    ],
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "codaw.transport",
          "name": "CodaW",
          "when": "codaw.hasProject",
          "icon": "icon.png"
        }
      ]
    },
    "configuration": {
      "title": "CodaW",
      "properties": {
        "codaw.enginePath": {
          "type": "string",
          "default": "codaw",
          "description": "Path to the codaw engine binary. Defaults to 'codaw' on PATH; point this at your built binary (e.g. /path/to/repo/codaw/codaw) during development."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "build:webviews": "vite build",
    "compile": "npm run build:webviews && webpack",
    "watch": "webpack --watch",
    "watch:webviews": "vite build --watch",
    "package": "npm run build:webviews && webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "eslint": "^10.5.0",
    "svelte": "^5.56.4",
    "ts-loader": "^9.6.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.1.3",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  },
  "dependencies": {
    "smol-toml": "^1.7.0"
  }
}
